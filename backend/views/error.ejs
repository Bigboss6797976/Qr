<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>提示</title>
  <style>
    body {
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
      margin: 0;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: #f5f5f5;
    }
    .error-card {
      background: white;
      padding: 40px;
      border-radius: 16px;
      text-align: center;
      box-shadow: 0 4px 20px rgba(0,0,0,0.1);
      max-width: 400px;
    }
    .error-icon {
      font-size: 60px;
      margin-bottom: 20px;
    }
    .error-message {
      font-size: 18px;
      color: #333;
      margin-bottom: 10px;
    }
    .error-code {
      font-size: 14px;
      color: #999;
    }
  </style>
</head>
<body>
  <div class="error-card">
    <div class="error-icon">⚠️</div>
    <div class="error-message"><%= message %></div>
    <div class="error-code">错误码: <%= code %></div>
  </div>
</body>
</html>

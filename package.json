{
  "name": "qr-payment-system",
  "version": "1.0.0",
  "description": "个人收款码美化聚合支付系统 - 苹果/安卓/电脑三端通用",
  "main": "backend/server.js",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "nodemon backend/server.js",
    "build": "echo 'Web assets ready'",
    "cap:sync": "npx cap sync",
    "cap:open:ios": "npx cap open ios",
    "cap:open:android": "npx cap open android",
    "cap:run:ios": "npx cap run ios",
    "cap:run:android": "npx cap run android",
    "electron:build": "cd electron && npm run build",
    "electron:pack": "cd electron && npm run pack",
    "electron:dist": "cd electron && npm run dist",
    "build:all": "npm run build && npm run cap:sync && cd electron && npm run build",
    "test": "echo 'Error: no test specified' && exit 1"
  },
  "keywords": ["qrcode", "payment", "alipay", "wechat", "聚合支付", "多端"],
  "author": "旭阳",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "ejs": "^3.1.9",
    "cors": "^2.8.5",
    "body-parser": "^1.20.2",
    "multer": "^1.4.5-lts.1",
    "qrcode": "^1.5.3",
    "jsqr": "^1.4.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/ios": "^6.0.0",
    "@capacitor/android": "^6.0.0",
    "@capacitor/camera": "^6.0.0",
    "@capacitor/filesystem": "^6.0.0",
    "@capacitor/share": "^6.0.0",
    "@capacitor/splash-screen": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0",
    "@capacitor/toast": "^6.0.0",
    "@capacitor/clipboard": "^6.0.0",
    "@capacitor/app": "^6.0.0",
    "@capacitor/preferences": "^6.0.0",
    "nodemon": "^3.0.1"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
